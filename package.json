{
  "name": "krn-gastown",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "scripts": {
    "typecheck": "tsc -b packages/contracts packages/cli packages/mcp packages/evals apps/dashboard",
    "test": "vitest run",
    "krn": "tsx packages/cli/src/main.ts",
    "eval:krn-init": "tsx packages/evals/src/validate-krn-init.ts --mode validate",
    "eval:krn-doctor": "tsx packages/evals/src/validate-krn-doctor.ts --mode validate",
    "eval:krn-review": "tsx packages/evals/src/validate-krn-review.ts --mode validate",
    "eval:krn-mcp": "tsx packages/evals/src/validate-krn-mcp.ts --mode validate",
    "eval:krn-mcp-transport": "tsx packages/evals/src/validate-krn-mcp-transport.ts --mode validate",
    "eval:krn-proposal-store": "tsx packages/evals/src/validate-krn-proposal-store.ts --mode validate",
    "eval:krn-mcp-proposal-tool": "tsx packages/evals/src/validate-krn-mcp-proposal-tool.ts --mode validate",
    "eval:krn-pending-review-view-model": "tsx packages/evals/src/validate-krn-pending-review-view-model.ts --mode validate",
    "eval:krn-dashboard-pending-review-ui": "tsx packages/evals/src/validate-krn-dashboard-pending-review-ui.ts --mode validate",
    "eval:krn-dashboard-promotion-review-ui": "tsx packages/evals/src/validate-krn-dashboard-promotion-review-ui.ts --mode validate",
    "eval:krn-proposal-review-decision": "tsx packages/evals/src/validate-krn-proposal-review-decision.ts --mode validate",
    "eval:krn-proposal-promotion": "tsx packages/evals/src/validate-krn-proposal-promotion.ts --mode validate",
    "eval:krn-eval": "tsx packages/evals/src/validate-krn-eval.ts --mode validate"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
