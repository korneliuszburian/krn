{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompactCheckpoint",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "created_at",
    "event",
    "trigger",
    "turn_id",
    "checkpoint_path",
    "project_root",
    "source_refs",
    "key_file_refs",
    "resume_rule",
    "cautions"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["compact_checkpoint"] },
    "status": { "type": "string", "enum": ["local_artifact", "reviewed", "stale", "superseded"] },
    "created_at": { "type": "string" },
    "event": { "type": "string", "enum": ["PreCompact", "PostCompact"] },
    "trigger": { "type": "string", "enum": ["manual", "auto", "unknown"] },
    "turn_id": { "type": "string" },
    "checkpoint_path": { "type": "string" },
    "project_root": { "type": "string" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "key_file_refs": { "type": "array", "items": { "type": "string" } },
    "resume_rule": { "type": "string" },
    "cautions": { "type": "array", "items": { "type": "string" } }
  }
}
