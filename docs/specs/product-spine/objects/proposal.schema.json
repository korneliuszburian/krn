{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "proposal_type",
    "title",
    "created_at",
    "owner",
    "proposed_change",
    "target_refs",
    "source_refs",
    "review_required",
    "failure_mode"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["proposal"] },
    "status": { "type": "string", "enum": ["draft", "ai_suggested", "needs_review", "approved", "rejected", "superseded"] },
    "proposal_type": { "type": "string", "enum": ["memory", "source", "eval", "skill", "schema", "dashboard", "api", "mcp"] },
    "title": { "type": "string" },
    "created_at": { "type": "string" },
    "owner": { "type": "string" },
    "proposed_change": { "type": "string" },
    "target_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "review_required": { "type": "boolean" },
    "failure_mode": { "type": "string" }
  }
}
