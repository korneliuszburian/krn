{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "memory_type",
    "title",
    "claim",
    "created_at",
    "source_refs",
    "evidence_refs",
    "confidence",
    "owner",
    "failure_mode",
    "review_trigger"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["memory_entry"] },
    "status": { "type": "string", "enum": ["draft", "ai_suggested", "needs_review", "approved", "stale", "superseded", "rejected"] },
    "memory_type": { "type": "string", "enum": ["fact", "decision", "pattern", "failure", "preference", "source_note", "checkpoint"] },
    "title": { "type": "string" },
    "claim": { "type": "string" },
    "created_at": { "type": "string" },
    "valid_from": { "type": ["string", "null"] },
    "expires_at": { "type": ["string", "null"] },
    "invalidates_when": { "type": "string" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "linked_entry_ids": { "type": "array", "items": { "type": "string" } },
    "eval_refs": { "type": "array", "items": { "type": "string" } },
    "confidence": { "type": "number" },
    "owner": { "type": "string" },
    "access": { "type": "string", "enum": ["workspace", "private", "public"] },
    "failure_mode": { "type": "string" },
    "review_trigger": { "type": "string" }
  }
}
