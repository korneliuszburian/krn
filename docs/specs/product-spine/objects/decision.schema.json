{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "decision_type",
    "title",
    "created_at",
    "decision",
    "rationale",
    "source_refs",
    "alternatives_rejected",
    "risk_if_wrong",
    "review_trigger"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["decision"] },
    "status": { "type": "string", "enum": ["draft", "approved", "stale", "superseded", "rejected"] },
    "decision_type": { "type": "string", "enum": ["product", "architecture", "eval", "memory", "security", "workflow"] },
    "title": { "type": "string" },
    "created_at": { "type": "string" },
    "decision": { "type": "string" },
    "rationale": { "type": "string" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "alternatives_rejected": { "type": "array", "items": { "type": "string" } },
    "risk_if_wrong": { "type": "string" },
    "review_trigger": { "type": "string" }
  }
}
