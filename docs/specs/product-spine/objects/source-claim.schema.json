{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceClaim",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "claim",
    "created_at",
    "source_ids",
    "source_refs",
    "evidence_grade",
    "used_for_decision",
    "risk_if_wrong"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["source_claim"] },
    "status": { "type": "string", "enum": ["draft", "approved", "stale", "superseded", "rejected"] },
    "claim": { "type": "string" },
    "created_at": { "type": "string" },
    "source_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "local_evidence_refs": { "type": "array", "items": { "type": "string" } },
    "evidence_grade": { "type": "string", "enum": ["A", "B", "C", "D", "mixed"] },
    "used_for_decision": { "type": "boolean" },
    "risk_if_wrong": { "type": "string" },
    "review_trigger": { "type": "string" }
  }
}
