{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "project_name",
    "created_at",
    "identity",
    "product_boundary",
    "current_phase",
    "source_refs",
    "guardrails",
    "next_allowed_surfaces",
    "blocked_surfaces"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["project_profile"] },
    "status": { "type": "string", "enum": ["draft", "active", "stale", "superseded"] },
    "project_name": { "type": "string" },
    "created_at": { "type": "string" },
    "identity": { "type": "string" },
    "product_boundary": { "type": "string" },
    "current_phase": { "type": "string" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "guardrails": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "next_allowed_surfaces": { "type": "array", "items": { "type": "string" } },
    "blocked_surfaces": { "type": "array", "items": { "type": "string" } }
  }
}
