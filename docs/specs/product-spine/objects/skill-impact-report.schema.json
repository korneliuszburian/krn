{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillImpactReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "created_at",
    "based_on_eval_run_id",
    "source_refs",
    "no_productivity_claim",
    "skill_decisions",
    "interpretation_caveat"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["product-spine.v1"] },
    "id": { "type": "string" },
    "kind": { "type": "string", "enum": ["skill_impact_report"] },
    "status": { "type": "string", "enum": ["local_artifact", "reviewed", "stale", "superseded"] },
    "created_at": { "type": "string" },
    "based_on_eval_run_id": { "type": "string" },
    "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "no_productivity_claim": { "type": "boolean" },
    "skill_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["skill", "decision", "reason", "explicit_minus_baseline", "evidence_refs"],
        "properties": {
          "skill": { "type": "string" },
          "decision": { "type": "string", "enum": ["keep", "keep_observe", "refine", "merge", "remove"] },
          "reason": { "type": "string" },
          "explicit_minus_baseline": { "type": "number" },
          "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    },
    "interpretation_caveat": { "type": "string" }
  }
}
