{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "krn-benchmark-live-suite-codex-output.schema.json",
  "type": "object",
  "required": [
    "selected_phase",
    "current_parent_goal",
    "latest_child_goal",
    "source_refs",
    "next_action",
    "should_claim_productivity_lift",
    "overclaim_boundary",
    "rationale"
  ],
  "additionalProperties": false,
  "properties": {
    "selected_phase": { "type": "string", "minLength": 1 },
    "current_parent_goal": { "type": "string", "minLength": 1 },
    "latest_child_goal": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "next_action": { "type": "string", "minLength": 1 },
    "should_claim_productivity_lift": { "type": "boolean" },
    "overclaim_boundary": { "type": "string", "minLength": 1 },
    "rationale": { "type": "string", "minLength": 1 }
  }
}
