{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "krn-research-pack-result.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "created_at",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "case_pass_rate",
    "total_assertions",
    "passed_assertions",
    "failed_assertions",
    "assertion_pass_rate",
    "cases",
    "generated_research_pack_path",
    "interpretation_caveat"
  ],
  "properties": {
    "schema_version": {
      "const": "krn-research-pack-result.v1"
    },
    "kind": {
      "const": "krn_research_pack_result"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "total_cases": {
      "type": "number"
    },
    "passed_cases": {
      "type": "number"
    },
    "failed_cases": {
      "type": "number"
    },
    "case_pass_rate": {
      "type": "number"
    },
    "total_assertions": {
      "type": "number"
    },
    "passed_assertions": {
      "type": "number"
    },
    "failed_assertions": {
      "type": "number"
    },
    "assertion_pass_rate": {
      "type": "number"
    },
    "cases": {
      "type": "array"
    },
    "generated_research_pack_path": {
      "type": ["string", "null"]
    },
    "interpretation_caveat": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
