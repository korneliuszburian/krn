{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://krn.local/schemas/krn-proposal-promotion-result.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "created_at",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "case_pass_rate",
    "total_assertions",
    "passed_assertions",
    "failed_assertions",
    "assertion_pass_rate",
    "cases",
    "stored_promotion_path",
    "applied_target_path",
    "interpretation_caveat"
  ],
  "properties": {
    "schema_version": { "const": "krn-proposal-promotion-result.v1" },
    "kind": { "const": "krn_proposal_promotion_eval_result" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "total_cases": { "type": "integer", "minimum": 0 },
    "passed_cases": { "type": "integer", "minimum": 0 },
    "failed_cases": { "type": "integer", "minimum": 0 },
    "case_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "total_assertions": { "type": "integer", "minimum": 0 },
    "passed_assertions": { "type": "integer", "minimum": 0 },
    "failed_assertions": { "type": "integer", "minimum": 0 },
    "assertion_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "passed", "assertions", "failure_mode", "message"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "assertions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "failure_mode": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stored_promotion_path": { "type": ["string", "null"] },
    "applied_target_path": { "type": ["string", "null"] },
    "interpretation_caveat": { "type": "string", "minLength": 1 }
  }
}
