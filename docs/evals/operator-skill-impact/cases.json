{
  "version": 1,
  "module_id": "operator-skill-impact",
  "description": "Compare neutral Codex runs with explicit repo-local operator-skill runs on KRN operating tasks.",
  "metrics": [
    "task_success_score",
    "source_grounding_score",
    "phase_discipline_score",
    "verification_score",
    "review_burden_score",
    "context_cost_score",
    "skill_routing_score",
    "repeat_failure_reduction_score"
  ],
  "cases": [
    {
      "id": "broad-next-step",
      "target_skill": "operator-intake",
      "expected_behavior": "The answer chooses the next smallest KRN operating-layer slice, ties it to goal-006/operator-skill-impact, and avoids dashboard/API drift.",
      "source_patterns": [
        "docs/goals/goal-006.md",
        "docs/product/final-product-plan.md",
        "docs/skills/operator-pipeline.md",
        "docs/memory/evals/2026-06-19--operator-skill-impact-loop.md"
      ],
      "metrics": [
        "task_success_score",
        "source_grounding_score",
        "phase_discipline_score",
        "verification_score",
        "context_cost_score"
      ],
      "variants": {
        "baseline": "Propose the next smallest implementation slice for this repository. Keep it concise and do not edit files.",
        "explicit": "Use $operator-intake to propose the next smallest implementation slice for this repository. Keep it concise and do not edit files.",
        "routing": "Propose the next smallest implementation slice for this repository. If a repo-local skill clearly applies, choose it explicitly; keep it concise and do not edit files."
      },
      "assertions": [
        {
          "id": "names_current_impact_goal",
          "type": "contains_any",
          "metric": "source_grounding_score",
          "values": ["goal-006", "operator-skill-impact", "impact gate", "skill-assisted", "baseline"]
        },
        {
          "id": "chooses_eval_or_operator_slice",
          "type": "contains_any",
          "metric": "phase_discipline_score",
          "values": ["eval", "operator-skill", "impact", "P2", "skill contract", "skill-assisted"]
        },
        {
          "id": "names_verification_surface",
          "type": "contains_any",
          "metric": "verification_score",
          "values": ["report", "run", "python3 scripts/evals", ".krn/evals", "verify", "baseline"]
        },
        {
          "id": "avoids_dashboard_api_drift",
          "type": "not_contains_any",
          "metric": "phase_discipline_score",
          "values": ["build the dashboard first", "start with dashboard", "API first", "full app", "dashboard MVP"]
        },
        {
          "id": "concise_answer",
          "type": "word_count_at_most",
          "metric": "context_cost_score",
          "max_words": 500
        }
      ],
      "failure_mode": "Codex jumps to dashboard/API/product build or proposes vague repo work instead of the current impact-eval slice."
    },
    {
      "id": "source-list-synthesis",
      "target_skill": "research-synthesis",
      "expected_behavior": "The answer extracts mechanisms from OpenAI/Matt sources and maps them to KRN implications, evals, and failure modes instead of listing links.",
      "source_patterns": [
        "docs/memory/openai-codex/2026-06-19--openai-cookbook-to-krn-pattern-map.md",
        "docs/memory/github-research/2026-06-19--mattpocock-skills-operator-pipeline.md",
        "docs/plans/canonical/SOURCES.md"
      ],
      "metrics": [
        "task_success_score",
        "source_grounding_score",
        "phase_discipline_score",
        "verification_score",
        "review_burden_score",
        "context_cost_score"
      ],
      "variants": {
        "baseline": "Given this repo's existing notes on OpenAI Cookbook eval loops and mattpocock/skills, state what KRN should extract as mechanisms. Do not edit files.",
        "explicit": "Use $research-synthesis. Given this repo's existing notes on OpenAI Cookbook eval loops and mattpocock/skills, state what KRN should extract as mechanisms. Do not edit files.",
        "routing": "Given this repo's existing notes on OpenAI Cookbook eval loops and mattpocock/skills, choose any repo-local skill that materially helps and state what KRN should extract as mechanisms. Do not edit files."
      },
      "assertions": [
        {
          "id": "extracts_mechanism",
          "type": "contains_any",
          "metric": "task_success_score",
          "values": ["mechanism", "pattern", "intervention", "workflow"]
        },
        {
          "id": "maps_to_krn_implication",
          "type": "contains_any",
          "metric": "source_grounding_score",
          "values": ["KRN implication", "for KRN", "operator skill", "operator pipeline"]
        },
        {
          "id": "includes_eval_or_falsification",
          "type": "contains_any",
          "metric": "verification_score",
          "values": ["eval", "falsification", "metric", "assertion", "compare", "baseline"]
        },
        {
          "id": "includes_failure_mode",
          "type": "contains_any",
          "metric": "review_burden_score",
          "values": ["failure mode", "risk", "harmful", "drift", "when it fails"]
        },
        {
          "id": "not_bibliography_only",
          "type": "not_contains_any",
          "metric": "phase_discipline_score",
          "values": ["just a list of links", "only a bibliography", "stars prove", "ranking proves"]
        },
        {
          "id": "concise_answer",
          "type": "word_count_at_most",
          "metric": "context_cost_score",
          "max_words": 700
        }
      ],
      "failure_mode": "Codex produces a bibliography or hype list instead of mechanism-level KRN knowledge."
    },
