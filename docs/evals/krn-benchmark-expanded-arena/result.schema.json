{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "krn-benchmark-expanded-arena-result.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "created_at",
    "mode",
    "total_cases",
    "passed_cases",
    "failed_cases",
    "case_pass_rate",
    "total_assertions",
    "passed_assertions",
    "failed_assertions",
    "assertion_pass_rate",
    "cases",
    "validated_task_registry_path",
    "generated_benchmark_report_path",
    "arena_summary",
    "scoring_summary",
    "interpretation_caveat"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "krn-benchmark-expanded-arena-result.v1" },
    "kind": { "const": "krn_benchmark_expanded_arena_result" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "mode": { "const": "validate" },
    "total_cases": { "type": "integer", "minimum": 0 },
    "passed_cases": { "type": "integer", "minimum": 0 },
    "failed_cases": { "type": "integer", "minimum": 0 },
    "case_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "total_assertions": { "type": "integer", "minimum": 0 },
    "passed_assertions": { "type": "integer", "minimum": 0 },
    "failed_assertions": { "type": "integer", "minimum": 0 },
    "assertion_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "passed", "assertions", "failure_mode", "message"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "assertions": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "failure_mode": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "validated_task_registry_path": {
      "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "generated_benchmark_report_path": {
      "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "arena_summary": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "arena_id",
            "task_count",
            "minimum_live_task_count_for_lift_claim",
            "task_family_count",
            "implementation_heavy_task_count",
            "quality_metric_count",
            "live_mode_explicit",
            "next_allowed_action"
          ],
          "additionalProperties": false,
          "properties": {
            "arena_id": { "type": "string", "minLength": 1 },
            "task_count": { "type": "integer", "minimum": 0 },
            "minimum_live_task_count_for_lift_claim": { "type": "integer", "minimum": 0 },
            "task_family_count": { "type": "integer", "minimum": 0 },
            "implementation_heavy_task_count": { "type": "integer", "minimum": 0 },
            "quality_metric_count": { "type": "integer", "minimum": 0 },
            "live_mode_explicit": { "type": "boolean" },
            "next_allowed_action": { "type": "string", "minLength": 1 }
          }
        },
        { "type": "null" }
      ]
    },
    "scoring_summary": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "scored_task_count",
            "baseline_score",
            "assisted_score",
            "assisted_minus_baseline",
            "benchmark_report_path"
          ],
          "additionalProperties": false,
          "properties": {
            "scored_task_count": { "type": "integer", "minimum": 0 },
            "baseline_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "assisted_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "assisted_minus_baseline": { "type": "number", "minimum": -1, "maximum": 1 },
            "benchmark_report_path": { "type": "string", "minLength": 1 }
          }
        },
        { "type": "null" }
      ]
    },
    "interpretation_caveat": { "type": "string", "minLength": 1 }
  }
}
